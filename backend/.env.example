# Server
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-domain.com

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nexus?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this
JWT_REFRESH_EXPIRE=30d

# Cloudinary (for file/image/video uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (optional but recommended for scaling)
REDIS_URL=redis://localhost:6379

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=Nexus <noreply@nexus.app>

# WebRTC TURN Server (for audio/video calls through NAT)
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=nexus
TURN_CREDENTIAL=nexus_secret

# App
MAX_FILE_SIZE=50mb
MAX_GROUP_MEMBERS=1000
